							{ "key": "Authorization", "value": "Bearer {{jwt_token}}" }
						],
						"url": "{{baseUrl}}/api/integration/mexc/sync-status"
					}
				},
				{
					"name": "Get Synced Raw Orders (DB)",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{jwt_token}}" }
						],
						"url": "{{baseUrl}}/api/integration/mexc/raw-orders?symbol=BTCUSDT"
					}
				},
				{
					"name": "Direct Orders Query (GET /allOrders)",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{jwt_token}}" }
						],
						"url": "{{baseUrl}}/api/integration/mexc/orders?symbol=BTCUSDT"
					}
				}
			]
		},
		{
			"name": "4. IOL Integration",
			"item": [
				{
					"name": "Save API Config (Username/Password)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{jwt_token}}" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"exchangeName\": \"IOL\",\n    \"apiKey\": \"YOUR_USERNAME\",\n    \"apiSecret\": \"YOUR_PASSWORD\"\n}"
						},
						"url": "{{baseUrl}}/api/exchange/config"
					}
				},
				{
					"name": "Login to IOL",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{jwt_token}}" }
						],
						"url": "{{baseUrl}}/api/exchange/iol/login"
					}
				},
				{
					"name": "Get Account Statement (Balances)",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{jwt_token}}" }
						],
						"url": "{{baseUrl}}/api/integration/iol/account-statement"
					}
				},
				{
					"name": "Get Portfolio (Argentina)",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{jwt_token}}" }
						],
						"url": "{{baseUrl}}/api/integration/iol/portfolio/argentina"
					}
				},
				{
					"name": "Get Portfolio (USA)",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{jwt_token}}" }
						],
						"url": "{{baseUrl}}/api/integration/iol/portfolio/estados_unidos"
					}
				},
				{
					"name": "Get List of Operations",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{jwt_token}}" }
						],
						"url": "{{baseUrl}}/api/integration/iol/operations"
					}
				},
				{
					"name": "Get Profile Data",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{jwt_token}}" }
						],
						"url": "{{baseUrl}}/api/integration/iol/profile"
					}
				}
			]
		},
		{
			"name": "5. Holdings & Portfolios",
			"item": [
				{
					"name": "Get All Holdings",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{jwt_token}}" }
						],
						"url": "{{baseUrl}}/api/holdings"
					}
				},
				{
					"name": "Get Portfolio Distribution",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{jwt_token}}" }
						],
						"url": "{{baseUrl}}/api/portfolio/distribution"
					}
				},
				{
					"name": "List Portfolio Names",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{jwt_token}}" }
						],
						"url": "{{baseUrl}}/api/portfolio/names"
					}
				}
			]
		},
		{
			"name": "4. Transactions",
			"item": [
				{
					"name": "Filter Transactions",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{jwt_token}}" }
						],
						"url": "{{baseUrl}}/transaction/filter?portfolioName=MyBinance&size=20"
					}
				}
			]
		}
	],
	"variable": [
		{ "key": "baseUrl", "value": "http://localhost:9080", "type": "string" },
		{ "key": "jwt_token", "value": "", "type": "string" }
	]
}
